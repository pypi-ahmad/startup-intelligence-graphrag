# Startup Intelligence GraphRAG runtime settings
# Prefix all overrides with SIRAG_

# Strict dataset policy (do not change in strict mode)
SIRAG_DATASET_REPO=deerfieldgreen/stk-sec-filings
SIRAG_DATASET_CONFIG=
SIRAG_DATASET_SPLITS=["train"]
SIRAG_STRICT_DATASET=true

# Local models via Ollama
SIRAG_OLLAMA_HOST=http://localhost:11434
SIRAG_EMBED_MODEL=qwen3-embedding:4b
SIRAG_GENERATOR_MODEL=granite4.1:8b
SIRAG_JUDGE_MODEL=granite4.1:8b
SIRAG_EXTENSION_JUDGE_MODEL=granite4.1:8b
SIRAG_OCR_MODEL=glm-ocr:latest
SIRAG_VISION_MODEL=qwen3.5:4b

# Optional advanced stage (Unsloth + PEFT + TRL)
SIRAG_ADAPTER_ENABLE=false
SIRAG_ADAPTER_BASE_MODEL=unsloth/granite-4.1-3b
SIRAG_ADAPTER_USE_4BIT=true
SIRAG_ADAPTER_MAX_SEQ_LENGTH=2048
SIRAG_ADAPTER_MAX_TRAIN_EXAMPLES=4000
SIRAG_ADAPTER_MAX_EVAL_EXAMPLES=400
SIRAG_ADAPTER_TRAIN_SPLIT=0.9
SIRAG_ADAPTER_LORA_R=16
SIRAG_ADAPTER_LORA_ALPHA=32
SIRAG_ADAPTER_LORA_DROPOUT=0.05
SIRAG_ADAPTER_LEARNING_RATE=0.0002
SIRAG_ADAPTER_PER_DEVICE_BATCH_SIZE=1
SIRAG_ADAPTER_GRADIENT_ACCUMULATION_STEPS=8
SIRAG_ADAPTER_MAX_STEPS=300
SIRAG_ADAPTER_EVAL_STEPS=50
SIRAG_ADAPTER_SAVE_STEPS=50
SIRAG_ADAPTER_LOG_STEPS=10
SIRAG_ADAPTER_MAX_NEW_TOKENS=256

# Corpus size
SIRAG_DEFAULT_N_COMPANIES=30

# Placeholder-first behavior for this phase
SIRAG_PLACEHOLDER_MODE=true
